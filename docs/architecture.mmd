%%{init: {"flowchart": {"htmlLabels": true, "curve": "basis"}, "themeVariables": {"fontSize": "15px", "fontFamily": "Inter, -apple-system, Segoe UI, sans-serif"}}}%%
flowchart TB
    User([NOC Operator])
    UI["NetPulse UI<br/><span style='font-size:11px;font-weight:400;font-family:JetBrains Mono,monospace'>Flask + SSE chat &middot; Cloud Run</span>"]

    subgraph ORCH["ADK SequentialAgent &middot; telecom_ops &middot; 4 LlmAgents on Gemini"]
        direction TB
        A1["1 &middot; Classifier"]
        A2["2 &middot; Network Investigator"]
        A3["3 &middot; CDR Analyzer"]
        A4["4 &middot; Response Formatter"]
        A1 -- "category, region" --> A2
        A2 -- "+ network_findings" --> A3
        A3 -- "+ cdr_findings" --> A4
    end

    MCP["MCP Toolbox<br/><span style='font-size:11px;font-weight:400;font-family:JetBrains Mono,monospace'>Cloud Run</span>"]

    subgraph DATA["Backends &middot; Google Cloud"]
        direction LR
        BQ[("BigQuery<br/><span style='font-size:11px;font-weight:400;font-family:JetBrains Mono,monospace'>network_events</span>")]
        ADB1[("AlloyDB<br/><span style='font-size:11px;font-weight:400;font-family:JetBrains Mono,monospace'>call_records &middot; NL2SQL</span>")]
        ADB2[("AlloyDB<br/><span style='font-size:11px;font-weight:400;font-family:JetBrains Mono,monospace'>incident_tickets</span>")]
    end

    Vertex["Vertex AI Gemini<br/><span style='font-size:11px;font-weight:400;font-family:JetBrains Mono,monospace'>3.1 Flash-Lite + 2.5 Flash failover</span>"]

    User --> UI --> A1
    A2 --> MCP --> BQ
    A3 --> MCP
    MCP -- "NL2SQL" --> ADB1
    A4 -- "INSERT" --> ADB2
    ORCH -. "LLM calls" .-> Vertex

    %% NetPulse palette: cream paper, deep ink, clay coral accent, pandan green
    classDef user        fill:#141413,stroke:#141413,color:#F4F0E6,font-weight:600
    classDef fe          fill:#ECE4D1,stroke:#CC785C,color:#141413,font-weight:600,stroke-width:1.5px
    classDef adk         fill:#F4F0E6,stroke:#DDD3BB,color:#141413,font-weight:500
    classDef mcp         fill:#ECE4D1,stroke:#4a8c5e,color:#2f5d3d,font-weight:600,stroke-width:1.5px
    classDef alloydb     fill:#F4F0E6,stroke:#CC785C,color:#141413,font-weight:600
    classDef alloydbWrite fill:#CC785C,stroke:#A85B40,color:#FAF7EE,font-weight:600
    classDef vertex      fill:#141413,stroke:#141413,color:#F4F0E6,font-weight:600

    class User user
    class UI fe
    class A1,A2,A3,A4 adk
    class MCP mcp
    class BQ,ADB1 alloydb
    class ADB2 alloydbWrite
    class Vertex vertex

    style ORCH fill:#FAF7EE,stroke:#CC785C,stroke-width:2px,stroke-dasharray:6 4,color:#141413
    style DATA fill:#FAF7EE,stroke:#DDD3BB,stroke-width:1.5px,color:#5A554D
