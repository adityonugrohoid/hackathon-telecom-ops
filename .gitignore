# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg

# Virtual environments
.venv/
venv/
env/

# Secrets / credentials — never commit these
.env
*.pem
*.key

# ADK scratch / temp
_smoke_test.py
/tmp/

# Project scratch
.scratch/

# Playwright MCP extraction + verification artifacts (kept locally,
# regenerable from the live site or static mockup; ~4 MB binary blobs)
.playwright-mcp/

# Internal-only docs (build journals, design spec, SSE wiring reference,
# migration plan) — kept locally, not published to the public repo
docs/internal/

# Iteration screenshots from the build process — not user-facing assets
docs/screenshots/

# Submission deck (large binary, kept locally — not in git)
*.pptx
*.pptx.*

# OS / IDE
.DS_Store
.idea/
.vscode/
*.swp
